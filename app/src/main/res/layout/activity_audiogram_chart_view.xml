<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/resultCaptureContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audiogram_result_title"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/patientInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#212121"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="10dp"
                tools:text="نام: علی رضایی — سن: ۳۵ سال\nتاریخ آزمون: ۱۴۰۴/۰۴/۲۹ (شمسی) — 2026/07/20 (میلادی)" />

            <com.masker.app.audiogram.AudiogramView
                android:id="@+id/audiogramView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="#FFFFFF" />

            <TextView
                android:id="@+id/legendText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/audiogram_legend"
                android:textSize="12sp"
                android:textColor="#212121" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/saveAudiogramButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/save" />

            <Button
                android:id="@+id/shareAudiogramButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/share" />
        </LinearLayout>

        <Button
            android:id="@+id/selectAsActiveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/select_as_active_audiogram" />

        <TextView
            android:id="@+id/activeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:visibility="gone"
            android:text="@string/this_is_active_audiogram" />

        <Button
            android:id="@+id/deleteAudiogramButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/delete" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/audiogram_disclaimer"
            android:textSize="11sp"
            android:textColor="#888888" />

    </LinearLayout>
</ScrollView>
