<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tinnitus_score_dialog_message"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/left_ear" />
    <EditText
        android:id="@+id/leftScoreEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/tinnitus_score_hint"
        android:inputType="number"
        android:importantForAutofill="no" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/right_ear" />
    <EditText
        android:id="@+id/rightScoreEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/tinnitus_score_hint"
        android:inputType="number"
        android:importantForAutofill="no" />

</LinearLayout>
