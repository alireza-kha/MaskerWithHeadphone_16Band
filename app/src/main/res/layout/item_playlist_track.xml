<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="6dp"
    android:background="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <ImageView
            android:id="@+id/trackThumbnailImage"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:src="@drawable/ic_music_note_placeholder" />

        <com.masker.app.playlist.EqualizerBarsView
            android:id="@+id/trackPlayingIndicator"
            android:layout_width="22dp"
            android:layout_height="15dp"
            android:layout_gravity="bottom|end"
            android:background="#B3000000"
            android:visibility="gone" />

        <CheckBox
            android:id="@+id/trackSelectCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:background="#B3000000"
            android:button="@android:drawable/checkbox_on_background"
            android:scaleX="0.9"
            android:scaleY="0.9"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/trackTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="11sp"
        tools:text="آهنگ نمونه" />

</LinearLayout>
