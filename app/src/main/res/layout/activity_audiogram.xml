<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/audiogram_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ===================== بخش معرفی و آماده‌سازی ===================== -->
        <LinearLayout
            android:id="@+id/introSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/audiogram_intro_text"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/audiogram_disclaimer"
                android:textSize="12sp"
                android:textColor="#B71C1C"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/viewHistoryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/view_history" />

            <EditText
                android:id="@+id/patientNameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/patient_name_hint"
                android:inputType="textPersonName"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/patientAgeEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:hint="@string/patient_age_hint"
                android:inputType="number"
                android:importantForAutofill="no" />

            <Button
                android:id="@+id/playCalibrationToneButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/play_calibration_tone" />

            <Button
                android:id="@+id/startTestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/start_test" />

            <Button
                android:id="@+id/directMaskedTestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/direct_masked_test" />

        </LinearLayout>

        <!-- ===================== بخش انجام آزمون ===================== -->
        <LinearLayout
            android:id="@+id/testSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center">

            <TextView
                android:id="@+id/testStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="24dp"
                tools:text="گوش راست — فرکانس ۲ از ۶ (۱۰۰۰ هرتز)" />

            <TextView
                android:id="@+id/testMaskingBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="italic"
                android:gravity="center"
                android:textColor="#B71C1C"
                android:text="@string/masking_phase_badge"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/testProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:max="100" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/audiogram_test_instruction"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/hearButton"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#2E7D6B"
                    android:text="@string/i_hear_it"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/dontHearButton"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#8A8A8A"
                    android:text="@string/i_dont_hear_it"
                    android:textSize="16sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/pausedStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/test_paused_status"
                android:textColor="#B71C1C"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

            <Button
                android:id="@+id/pauseResumeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/pause_test" />

        </LinearLayout>

        <!-- ===================== بخش نتیجه ===================== -->
        <LinearLayout
            android:id="@+id/resultSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/resultCaptureContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/audiogram_result_title"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/patientInfoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="10dp"
                    tools:text="نام: علی رضایی — سن: ۳۵ سال\nتاریخ آزمون: ۱۴۰۴/۰۴/۲۹ (شمسی) — 2026/07/20 (میلادی)" />

                <com.masker.app.audiogram.AudiogramView
                    android:id="@+id/audiogramView"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:background="#FFFFFF" />

                <TextView
                    android:id="@+id/legendText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/audiogram_legend"
                    android:textSize="12sp"
                    android:textColor="#212121" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/saveAudiogramButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/save" />

                <Button
                    android:id="@+id/shareAudiogramButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/share" />
            </LinearLayout>

            <Button
                android:id="@+id/retakeTestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/retake_test" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/audiogram_disclaimer"
                android:textSize="11sp"
                android:textColor="#888888" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
